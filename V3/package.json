{
  "name": "cc4-embedded-system",
  "version": "3.0.1",
  "description": "A modern typescript version of makefsdata based on html-minifier-next and lwIP v1.3.1",
  "bin": {
    "cc4es": "./dist/gui.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx src/gui.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "lwip",
    "makefsdata",
    "stm32",
    "embedded-system",
    "html-minifier",
    "html-minifier-next",
    "html-compressor"
  ],
  "author": "LunaticGhoulPiano",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "html-minifier-next": "^6.1.2",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/open": "^6.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
